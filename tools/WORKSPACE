load("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

# 1. Upgrade rules_go to a version that supports modern Go SDK download paths
http_archive(
    name = "io_bazel_rules_go",
    sha256 = "207fad3e6689135c5d8713e5a17ba9d1290238f47b9ba545b63d9303406209c6",
    urls = [
        "https://github.com/bazelbuild/rules_go/releases/download/v0.24.7/rules_go-v0.24.7.tar.gz",
        "https://mirror.bazel.build/github.com/bazelbuild/rules_go/releases/download/v0.24.7/rules_go-v0.24.7.tar.gz",
    ],
)

# 2. Upgrade gazelle to match the rules_go version matrix
http_archive(
    name = "bazel_gazelle",
    sha256 = "b85f559028b56dfc47cdbc0eb3eb92fc3ab6e84dbb85cf3dbd0bc10f06b97621",
    urls = [
        "https://github.com/bazelbuild/bazel-gazelle/releases/download/v0.22.0/bazel-gazelle-v0.22.0.tar.gz",
        "https://mirror.bazel.build/github.com/bazelbuild/bazel-gazelle/releases/download/v0.22.0/bazel-gazelle-v0.22.0.tar.gz",
    ],
)

load("@io_bazel_rules_go//go:def.bzl", "go_repository", "go_rules_dependencies", "go_register_toolchains")

# Declare Go direct dependencies required by your tools
go_repository(
    name = "com_github_gopkg_v2",
    importpath = "gopkg.in/yaml.v2",
    tag = "v2.3.0",
)

go_rules_dependencies()

# Force an explicitly supported, active Go SDK download to bypass the 403 error
go_register_toolchains(version = "1.16.5")

load("@bazel_gazelle//:deps.bzl", "gazelle_dependencies")
gazelle_dependencies()

